# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/

# Virtual environments
.venv

# Tooling caches (ruff/mypy/pytest land in Story 1.2; preempt cache leaks now)
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage*
htmlcov/
coverage.xml

# Editor / IDE
.idea/
.vscode/

# OS
.DS_Store

# MkDocs build artifact — never commit; CI builds it at _site/ per ADR-009 + ADR-011
_site/

# Override user-global *.md exclusion (re-include Markdown docs for this project)
!*.md
!**/*.md
