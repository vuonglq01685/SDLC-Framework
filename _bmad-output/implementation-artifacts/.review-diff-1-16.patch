+@_SKIP_NO_UV
+def test_sdlc_init_via_subprocess_creates_layout(tmp_path: Path) -> None:
+    result = subprocess.run(
+        ["uv", "run", "sdlc", "init"],
+        cwd=tmp_path,
+        capture_output=True,
+        text=True,
+        check=False,
