+    """Build a minimal Typer context with obj dict."""
+    ctx = typer.Context(command=typer.core.TyperCommand("test"))
+    ctx.ensure_object(dict)
+    ctx.obj["no_color"] = no_color
+    ctx.obj["json"] = json_mode
