    {
      "id": "check_no_hardcoded_secrets_noqa_escape",
      "label": "noqa:secret Escape Hatch Pattern",
      "file_type": "rationale",
      "source_file": "scripts/check_no_hardcoded_secrets.py",
      "source_location": "line 8",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Every suppression of a hardcoded-secret lint warning must carry an audit trail via '# noqa: secret -- <reason>' of at least 10 characters. Plain '# noqa: secret' without reason is itself a violation, ensuring suppressions are traceable and deliberate (NFR-SEC-1)."
    },
