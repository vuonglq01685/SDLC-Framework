    {
      "id": "concurrency_locks_posix_only",
      "label": "POSIX-Only flock Design Decision",
      "file_type": "rationale",
      "source_file": "src/sdlc/concurrency/locks.py",
      "source_location": "line 1",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "The file locking module uses fcntl.flock which is POSIX-only (Architecture §573). The async path offloads blocking flock calls via asyncio.to_thread (Architecture §727, Decision B2) to avoid blocking the event loop. Windows users receive ImportError at module import time. The concurrency/__init__.py conditionally imports locks only on non-Windows platforms."
    },
