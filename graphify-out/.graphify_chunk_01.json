    {
      "id": "ids_kebab_slug_pattern",
      "label": "Kebab-Case Slug Validation Pattern",
      "file_type": "rationale",
      "source_file": "src/sdlc/ids/parsers.py",
      "source_location": "line 26",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "All identifier slugs must match lowercase kebab-case (^[a-z0-9]+(?:-[a-z0-9]+)*$). IDs follow the hierarchical pattern EPIC-<slug>-S<NN>-<slug>-T<NN>-<slug>. The private _SLUG_RE is shared between parsers.py and builders.py (intra-module import allowed by boundary rules). Numbers are zero-padded to 2 digits with max value 99."
    }
