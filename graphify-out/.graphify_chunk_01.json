    {
      "id": "check_module_boundaries_layered_dag",
      "label": "Layered DAG Architecture Constraint",
      "file_type": "rationale",
      "source_file": "scripts/check_module_boundaries.py",
      "source_location": "line 1",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "The layered DAG (Architecture §1073 + §1052) enforces that higher-level modules (engine, dispatcher, cli) cannot be imported by lower-level foundation modules (errors, ids, contracts, config, concurrency). This prevents circular dependencies and enforces separation of concerns. ADR-010 encodes these rules. Known gaps include adopt->cli widening and dashboard read-only semantics which are not expressible at import-graph level."
    },
